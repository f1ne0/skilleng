# ── SkillEng backend — пример переменных окружения ──
# Скопируй в .env для локального запуска. На Render задаётся через render.yaml / Dashboard.

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skilleng?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# CORS — адрес фронтенда (через запятую можно несколько)
CORS_ORIGIN=http://localhost:5173

# Refresh-кука: для разных доменов (prod) — none; локально можно strict
REFRESH_COOKIE_SAMESITE=strict

# Google Gemini (обязателен)
GEMINI_API_KEY=your-gemini-api-key

# ── Хранилище файлов ──
# local = диск бэкенда (offline). r2 = Cloudflare R2 (нужны R2_* ниже).
STORAGE_DRIVER=local
BACKEND_PUBLIC_URL=http://localhost:3000
# LOCAL_STORAGE_DIR=./storage

# ── R2 (опционально, только при STORAGE_DRIVER=r2) ──
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=
