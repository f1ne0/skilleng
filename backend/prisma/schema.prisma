generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum LearningGoal {
  TRAVEL
  BUSINESS
  ACADEMIC
  DAILY
  EXAM_PREP
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseCategory {
  GRAMMAR
  VOCABULARY
  BUSINESS_ENGLISH
  IELTS
  CONVERSATION
  PRONUNCIATION
  LISTENING
  READING
  WRITING
  EXAM_PREP
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE // один правильный из нескольких вариантов
  FILL_BLANK // вставить пропущенное слово
  DRAG_DROP // собрать предложение из слов
  MATCH_PAIRS // сопоставить пары (слово ↔ перевод)
  SHORT_WRITING // открытый ответ, оценивает AI (в Шаге 10)
  SPEAKING_RESPONSE // устный ответ: запись аудио, оценивает AI (Блок 5)
}

enum Skill {
  READING
  LISTENING
  SPEAKING
  WRITING
}

enum TopicSkill {
  // 4 вида речевой деятельности + языковые аспекты.
  // Grammar hub — частный случай: skill=GRAMMAR
  READING
  LISTENING
  SPEAKING
  WRITING
  GRAMMAR
  VOCABULARY
}

enum MessageRole {
  USER
  ASSISTANT
}

model RefreshToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique
  // храним только SHA-256 хэш, не сам токен.
  // если БД утечёт — токены нельзя использовать.

  expiresAt DateTime

  // Metadata для безопасности
  userAgent String? @db.Text
  ipAddress String?

  revokedAt DateTime?
  // null = активный, есть значение = отозван

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String?
  role         Role    @default(STUDENT)

  // Profile
  level          CefrLevel?
  goal           LearningGoal?
  nativeLanguage String?
  interests      String[]      @default([])
  avatarUrl      String?
  bio            String?       @db.Text

  // Status
  onboardingCompleted Boolean @default(false)
  emailVerified       Boolean @default(false)
  isActive            Boolean @default(true)

  // Tracking
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  totalXp     Int       @default(0)

  // Streak tracking
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?

  // Relations
  ownedCourses      Course[]           @relation("OwnedCourses")
  enrollments       CourseEnrollment[]
  lessonCompletions LessonCompletion[]
  answerSubmissions AnswerSubmission[]
  achievements      UserAchievement[]
  conversations     Conversation[]
  groupMemberships  GroupMembership[]
  ownedGroups       Group[]            @relation("OwnedGroups")
  vocabularyEntries VocabularyEntry[]
  placementTests    PlacementTest[]
  learningPath      LearningPath?
  progressSnapshots ProgressSnapshot[]
  examAttempts      ExamAttempt[]

  // Token
  refreshTokens RefreshToken[]

  @@index([email])
}

model UserAchievement {
  id            String @id @default(uuid())
  userId        String
  achievementId String
  // строковый ID из каталога (achievements.constants.ts).
  // НЕ FK — каталог хранится в коде, не в БД.

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model Course {
  id            String         @id @default(uuid())
  slug          String         @unique
  title         String
  description   String         @db.Text
  level         CefrLevel?
  category      CourseCategory
  coverImageUrl String?
  status        CourseStatus   @default(DRAFT)
  price         Decimal?       @db.Decimal(10, 2)

  ownerId String
  owner   User   @relation("OwnedCourses", fields: [ownerId], references: [id], onDelete: Cascade)

  // курс-предпосылка: этот курс закрыт, пока не пройден prerequisite (все его уроки)
  prerequisiteCourseId String?
  prerequisite         Course?  @relation("CoursePrereq", fields: [prerequisiteCourseId], references: [id], onDelete: SetNull)
  dependents           Course[] @relation("CoursePrereq")

  enrollments CourseEnrollment[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lessons     Lesson[]
  exams       Exam[]

  @@index([status, category])
  @@index([ownerId])
}

model CourseEnrollment {
  id       String @id @default(uuid())
  userId   String
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Lesson {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  content     String  @db.Text
  // основное содержимое урока — markdown текст

  videoUrl    String?
  audioUrl    String?
  durationSec Int?
  // примерная длительность в секундах, для UI ("5 мин")

  order Int
  // позиция внутри курса, начинается с 0

  isPreview Boolean @default(false)
  // если true — урок доступен всем без записи на курс (как "пробник")

  skillFocus Skill?
  // какой вид речевой деятельности тренирует урок (для навыковых хабов)

  availableFrom DateTime?
  // гибридное открытие (управляет учитель):
  //   null            → обычная последовательная блокировка (по порядку)
  //   дата в будущем  → урок закрыт до этой даты (расписание)
  //   дата в прошлом  → учитель открыл урок вручную (вне очереди)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)
  // тема-справочник (Блок 6): урок служит "тренажёром" темы

  status LessonStatus @default(DRAFT)

  completions LessonCompletion[]
  questions   Question[]

  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@index([courseId, order])
  @@index([status])
  @@index([topicId])
}

model LessonCompletion {
  id       String @id @default(uuid())
  userId   String
  lessonId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Question {
  id       String @id @default(uuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  type   QuestionType
  prompt String       @db.Text
  // сам текст вопроса, виден всегда

  payload Json
  // type-specific данные. Для MULTIPLE_CHOICE: { options, correctIndex }
  // Для FILL_BLANK: { text, correctAnswers, caseSensitive }
  // и т.д. Структура валидируется в сервисе.

  explanation String? @db.Text
  // показывается после ответа (правильного или нет)

  order  Int
  points Int @default(10)
  // сколько XP за правильный ответ

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  answerSubmissions AnswerSubmission[]

  @@index([lessonId, order])
}

model AnswerSubmission {
  id         String @id @default(uuid())
  userId     String
  questionId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answer Json
  // структура зависит от типа вопроса
  // MULTIPLE_CHOICE: { selectedIndex: 2 }
  // FILL_BLANK: { answer: "go" }
  // DRAG_DROP: { orderedWords: ["I'm", "going", ...] }
  // MATCH_PAIRS: { matches: [{ left, right }, ...] }
  // SHORT_WRITING: { text: "..." }

  isCorrect    Boolean?
  // null = не оценено (SHORT_WRITING до прихода AI-оценки)
  pointsEarned Int      @default(0)
  // блокируется при первом правильном ответе

  attemptCount Int @default(1)
  // сколько раз пересдавал

  firstCorrectAt DateTime?
  // когда впервые ответил правильно (для аналитики позже)

  submittedAt DateTime @default(now())
  // время ПОСЛЕДНЕЙ попытки

  // AI evaluation (для SHORT_WRITING)
  aiFeedback String? @db.Text
  aiScore    Int? // 0-100, оценка AI

  // null = не оценено (другой тип вопроса или ещё не оценено)
  @@unique([userId, questionId])
  // одна запись на пару (юзер, вопрос). Пересдача → update, не insert.
  @@index([userId])
  @@index([questionId])
  @@index([firstCorrectAt])
  // под weekly leaderboard: groupBy с where firstCorrectAt >= weekAgo
}

model Conversation {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title String @default("New chat")
  // авто-генерится из первого сообщения юзера

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  // если null — общий чат
  // если есть — AI использует контент урока как контекст

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([lessonId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    MessageRole
  content String      @db.Text

  // Tracking стоимости (для аналитики и лимитов)
  tokensInput  Int?
  tokensOutput Int?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

enum SnapshotLabel {
  PRE // замер до эксперимента — не перезаписывается
  POST // замер после — не перезаписывается
  WEEKLY // регулярный срез (cron)
}

model ProgressSnapshot {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label SnapshotLabel

  level    CefrLevel?
  totalXp  Int
  accuracy Float
  // доля правильных среди оценённых ответов на момент среза

  skillBreakdown Json
  // { READING: 0.8, LISTENING: 0.6, SPEAKING: null, WRITING: 0.7 }
  // null = по навыку ещё нет оценённых ответов

  takenAt DateTime @default(now())

  // сырьё педагогического эксперимента: PRE/POST по контрольной
  // и экспериментальной группам
  @@index([userId, label])
}

enum PathNodeType {
  LESSON // refId = lessonId
  SKILL_BLOCK // зарезервировано: группа уроков одного навыка
  CHECKPOINT // контрольная точка: повторная диагностика (адаптивный тест)
  REVIEW // SRS-сессия повтора словаря
}

enum PathNodeStatus {
  LOCKED
  AVAILABLE
  COMPLETED
}

model LearningPath {
  id     String @id @default(uuid())
  userId String @unique
  // один активный путь на юзера; generate пересоздаёт
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  basedOnLevel CefrLevel
  goal         LearningGoal?

  createdAt DateTime @default(now())

  nodes PathNode[]
}

model PathNode {
  id     String       @id @default(uuid())
  pathId String
  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  order Int
  type  PathNodeType
  refId String?
  // LESSON → lessonId. Без FK: урок может быть удалён, узел останется в истории

  skillFocus Skill?

  status      PathNodeStatus @default(LOCKED)
  completedAt DateTime?

  @@index([pathId, order])
}

model Topic {
  id    String     @id @default(uuid())
  title String
  skill TopicSkill
  level CefrLevel

  theoryContent String @db.Text
  // markdown-справочник: правило/объяснение/примеры

  order Int
  // позиция внутри пары (skill, level)

  lessons Lesson[]
  // привязанные уроки-тренажёры

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skill, level])
}

enum PlacementStatus {
  IN_PROGRESS
  COMPLETED
}

model PlacementTest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status PlacementStatus @default(IN_PROGRESS)

  ability        Float @default(0)
  // theta по шкале -3..+3, старт 0 (≈ середина B1)
  questionsAsked Int   @default(0)

  currentItemId String?
  // какой вопрос сейчас выдан студенту (server-authoritative:
  // ответ принимается только на этот item, клиент не выбирает вопросы сам)

  estimatedLevel CefrLevel?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  responses PlacementResponse[]

  @@index([userId])
}

model PlacementResponse {
  id     String        @id @default(uuid())
  testId String
  test   PlacementTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  itemId     String
  difficulty Float
  isCorrect  Boolean
  abilityAfter Float
  // траектория ability — сырые данные для методической главы (CAT/IRT)

  answeredAt DateTime @default(now())

  @@index([testId])
}

model PlacementItem {
  // Калиброванный банк заданий входного теста.
  // Наполняется генерацией (Блок 2) или ручным seed
  id String @id @default(uuid())

  level      CefrLevel
  difficulty Float
  // -3..+3 по шкале theta; центр уровня + разброс

  type    QuestionType
  prompt  String       @db.Text
  payload Json
  // та же структура, что у Question.payload (валидируется validatePayloadByType)

  createdAt DateTime @default(now())

  @@index([difficulty])
}

model VocabularyEntry {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  term        String
  translation String
  example     String? @db.Text
  partOfSpeech String?
  sourceLessonId String?
  // из какого урока добавлено слово (без FK — урок может быть удалён)

  // SRS-состояние (SM-2, см. vocabulary/srs.utils.ts)
  repetitions    Int       @default(0)
  // число подряд успешных повторов (quality >= 3)
  easeFactor     Float     @default(2.5)
  // коэффициент лёгкости, нижняя граница 1.3
  intervalDays   Int       @default(0)
  dueAt          DateTime  @default(now())
  // когда слово должно появиться в повторе. Новое слово — сразу due
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewLogs ReviewLog[]

  @@index([userId, dueAt])
  // основной запрос SRS: "слова юзера с dueAt <= now"
}

model ReviewLog {
  id      String          @id @default(uuid())
  entryId String
  entry   VocabularyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId  String
  // дублируем userId для выборок по юзеру без join

  quality      Int
  // 0-5: самооценка вспоминания (SM-2). 0-2 = забыл, 3-5 = вспомнил
  prevInterval Int
  newInterval  Int

  reviewedAt DateTime @default(now())

  // лог нужен не только SRS: это сырые данные для педагогического
  // эксперимента (динамика запоминания, кривая забывания)
  @@index([userId, reviewedAt])
}

model Group {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation("OwnedGroups", fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  inviteCode String @unique

  memberships GroupMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([inviteCode])
}

model GroupMembership {
  id      String @id @default(uuid())
  groupId String
  userId  String

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  // один юзер не может дважды быть в одной группе
  @@index([groupId])
  @@index([userId])
}

// ===== ЭКЗАМЕНЫ / КОНТРОЛЬНЫЕ =====
// Программа: 18 юнитов за 2 семестра. После каждых 3 юнитов — CHECKPOINT,
// в конце семестра — FINAL. Авто-проверяемые типы вопросов (мгновенный балл).

enum ExamType {
  CHECKPOINT // промежуточная контрольная (после 3 юнитов)
  FINAL      // семестровый экзамен
}

model Exam {
  id       String   @id @default(uuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title        String
  type         ExamType
  order        Int
  unitsLabel   String?
  // "Units 1-3" — диапазон покрываемых юнитов (для UI)
  passingScore Int      @default(60)
  // % правильных для зачёта

  questions ExamQuestion[]
  attempts  ExamAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, order])
}

model ExamQuestion {
  id     String @id @default(uuid())
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  type    QuestionType
  prompt  String       @db.Text
  payload Json
  // та же структура, что у Question.payload (валидируется validatePayloadByType)
  points  Int          @default(10)
  order   Int

  @@index([examId, order])
}

model ExamAttempt {
  id     String @id @default(uuid())
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status       String   @default("IN_PROGRESS")
  // IN_PROGRESS | COMPLETED
  score        Int?
  // % правильных (0-100)
  totalPoints  Int      @default(0)
  earnedPoints Int      @default(0)
  passed       Boolean?

  answers Json?
  // снимок ответов студента: [{ questionId, answer, isCorrect, pointsEarned }]

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([examId])
  @@index([userId])
}
